NODE_ENV=development
PORT=3000
SITE_URL=http://localhost:3000
TRUST_PROXY=0

# Desenvolvimento local com variáveis individuais:
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=admin_system
DB_CONNECTION_LIMIT=10

# Alternativas para produção (use URL completa OU variáveis individuais):
# DATABASE_URL=mysql://usuario:senha@host:3306/banco
# MYSQL_URL=mysql://usuario:senha@host:3306/banco
#
# Variáveis individuais nativas do serviço MySQL no Railway:
# MYSQLHOST=mysql.railway.internal
# MYSQLPORT=3306
# MYSQLUSER=usuario
# MYSQLPASSWORD=senha
# MYSQLDATABASE=banco
#
# Ative somente quando o provedor exigir TLS. A CA deve conter o certificado,
# não um caminho de arquivo. A validação do certificado permanece habilitada.
# DB_SSL=true
# DB_SSL_CA=-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----

SESSION_SECRET=troque-esta-chave-por-uma-sequencia-longa-e-aleatoria
SESSION_MAX_AGE_MS=28800000
SESSION_COOKIE_SECURE=false

BCRYPT_ROUNDS=12
DEFAULT_ADMIN_NAME=ADMIN
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=troque-esta-senha
